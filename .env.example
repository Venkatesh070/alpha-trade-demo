# API base URL — empty in local dev uses Vite proxy (/api → localhost:4000)
# Production: https://exness-india-server.onrender.com
VITE_API_URL=

# Verification email redirect — must be a Firebase Authorized domain
# Production: https://exness-india-server.onrender.com
VITE_APP_URL=http://localhost:8080

# Firebase client config — get from Firebase Console → Project settings → Your apps → Web
# Also enable Google sign-in: Authentication → Sign-in method → Google → Enable
# https://console.firebase.google.com/project/exness-india/settings/general
VITE_FIREBASE_API_KEY=YOUR_FIREBASE_WEB_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=exness-india.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=exness-india
VITE_FIREBASE_STORAGE_BUCKET=exness-india.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_MESSAGING_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_APP_ID
VITE_FIREBASE_MEASUREMENT_ID=YOUR_MEASUREMENT_ID

# App URL for Firebase email action links — must be a Firebase Authorized domain
APP_URL=http://localhost:8080

# Firebase Admin SDK — used for admin API token verification (server-side only)
# Firebase Console → Project settings → Service accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT_JSON=
# Or:
# FIREBASE_PROJECT_ID=exness-india
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@exness-india.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
